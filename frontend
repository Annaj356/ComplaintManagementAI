<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>FrontDesk — Campus Complaint Desk</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Roboto+Slab:wght@500;700&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@500;600&display=swap" rel="stylesheet">
<style>
  :root{
    --paper: #ffffff;
    --paper-raised: #ffffff;
    --ink: #0f3d73;
    --ink-soft: #4a76a8;
    --line: #bcd6ef;
    --line-soft: #e3eefb;
    --red: #b23a2f;
    --green: #3f6b4a;
    --gold: #a97a1f;
    --blue: #1d6fd1;
    --radius: 3px;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:
      radial-gradient(ellipse at top left, rgba(255,255,255,0.35), transparent 60%),
      var(--paper);
    color:var(--ink);
    font-family:'Inter', sans-serif;
    min-height:100vh;
  }
  ::selection{ background: var(--red); color:white; }

  h1,h2,h3{ font-family:'Roboto Slab', serif; margin:0; letter-spacing:-0.01em; }
  .mono{ font-family:'IBM Plex Mono', monospace; }
  a{ color:inherit; }
  button{ font-family:'Inter', sans-serif; cursor:pointer; }
  input, textarea, select{ font-family:'Inter', sans-serif; }

  .topbar{
    display:flex; align-items:center; justify-content:space-between;
    padding:20px 32px;
    border-bottom:2px solid var(--ink);
  }
  .brand{ display:flex; align-items:baseline; gap:10px; }
  .brand h1{ font-size:22px; }
  .brand .tag{ font-size:11px; color:var(--ink-soft); text-transform:uppercase; letter-spacing:0.14em; }
  .userchip{ display:flex; align-items:center; gap:14px; font-size:13px; color:var(--ink-soft); }
  .logout{
    background:none; border:1px solid var(--ink); color:var(--ink);
    padding:6px 12px; border-radius:var(--radius); font-size:12px;
    text-transform:uppercase; letter-spacing:0.08em;
  }
  .logout:hover{ background:var(--ink); color:var(--paper); }

  .tabs{ display:flex; gap:2px; padding:0 32px; margin-top:22px; }
  .tab{
    padding:10px 20px 12px;
    background:var(--line-soft);
    border:1px solid var(--line);
    border-bottom:none;
    border-radius:8px 8px 0 0;
    font-size:13px; text-transform:uppercase; letter-spacing:0.08em;
    color:var(--ink-soft);
    position:relative; top:1px;
  }
  .tab.active{
    background:var(--paper-raised);
    color:var(--ink);
    border-color:var(--ink);
    font-weight:600;
  }

  .panel{
    margin:0 32px 40px;
    background:var(--paper-raised);
    border:1px solid var(--ink);
    border-radius:0 6px 6px 6px;
    padding:36px;
    min-height:340px;
  }

  .field{ margin-bottom:18px; }
  .field label{
    display:block; font-size:11px; text-transform:uppercase; letter-spacing:0.1em;
    color:var(--ink-soft); margin-bottom:6px;
  }
  .field input, .field textarea{
    width:100%; padding:10px 12px; border:1px solid var(--line);
    background:var(--paper); border-radius:var(--radius); font-size:14px; color:var(--ink);
  }
  .field input:focus, .field textarea:focus{
    outline:2px solid var(--blue); outline-offset:1px; border-color:var(--blue);
  }
  .field textarea{ resize:vertical; min-height:110px; }

  .btn-primary{
    background:var(--ink); color:var(--paper); border:none;
    padding:11px 22px; border-radius:var(--radius);
    font-size:13px; text-transform:uppercase; letter-spacing:0.08em; font-weight:600;
  }
  .btn-primary:hover{ background:var(--red); }
  .btn-primary:disabled{ background:var(--line); cursor:not-allowed; }

  .error-msg{
    background:#f7e6e3; border:1px solid var(--red); color:var(--red);
    padding:10px 14px; border-radius:var(--radius); font-size:13px; margin-bottom:16px;
  }
  .info-msg{
    background:#e7eef1; border:1px solid var(--blue); color:var(--blue);
    padding:10px 14px; border-radius:var(--radius); font-size:13px; margin-bottom:16px;
  }

  /* ---------- login/signup ---------- */
  .auth-wrap{
    min-height:100vh; display:flex; align-items:center; justify-content:center;
    padding:40px 20px;
  }
  .pass-card{
    width:100%; max-width:420px;
    background:var(--paper-raised);
    border:1.5px solid var(--ink);
    border-radius:6px;
    padding:38px 36px 30px;
    position:relative;
  }
  .pass-card::before{
    content:"";
    position:absolute; top:14px; left:14px; right:14px; bottom:14px;
    border:1px dashed var(--line);
    border-radius:3px;
    pointer-events:none;
  }
  .pass-eyebrow{
    font-size:11px; letter-spacing:0.18em; text-transform:uppercase;
    color:var(--ink-soft); margin-bottom:6px;
  }
  .pass-card h1{ font-size:26px; margin-bottom:4px; }
  .pass-sub{ font-size:13px; color:var(--ink-soft); margin-bottom:28px; }
  .switcher{
    display:flex; margin-bottom:24px; border:1px solid var(--ink); border-radius:var(--radius); overflow:hidden;
  }
  .switcher button{
    flex:1; padding:9px; background:var(--paper); border:none; font-size:12px;
    text-transform:uppercase; letter-spacing:0.08em; color:var(--ink-soft);
  }
  .switcher button.active{ background:var(--ink); color:var(--paper); }

  /* ---------- ticket cards (my complaints) ---------- */
  .ticket-grid{ display:flex; flex-direction:column; gap:16px; }
  .ticket{
    position:relative;
    background:var(--paper);
    border:1px dashed var(--line);
    border-radius:6px;
    padding:20px 24px;
    display:flex; gap:20px; align-items:flex-start; justify-content:space-between;
  }
  .ticket::before, .ticket::after{
    content:""; position:absolute; width:14px; height:14px; background:var(--paper-raised);
    border-radius:50%; top:50%; transform:translateY(-50%);
  }
  .ticket::before{ left:-8px; border:1px dashed var(--line); border-left:none; }
  .ticket::after{ right:-8px; border:1px dashed var(--line); border-right:none; }
  .ticket-main{ flex:1; }
  .ticket-id{ font-size:11px; color:var(--ink-soft); margin-bottom:4px; }
  .ticket-title{ font-size:17px; margin-bottom:6px; }
  .ticket-desc{ font-size:13px; color:var(--ink-soft); margin-bottom:10px; line-height:1.5; }
  .ticket-meta{ display:flex; flex-wrap:wrap; gap:8px; font-size:11px; color:var(--ink-soft); }
  .ticket-meta span{ background:var(--line-soft); padding:3px 9px; border-radius:12px; }

  .stamp-col{ display:flex; flex-direction:column; align-items:flex-end; gap:8px; min-width:118px; }
  .stamp{
    font-family:'IBM Plex Mono', monospace;
    font-size:11px; text-transform:uppercase; letter-spacing:0.06em;
    border:2px solid; border-radius:4px; padding:4px 10px;
    transform:rotate(-4deg);
    font-weight:600;
  }
  .stamp.priority-Critical{ color:var(--red); border-color:var(--red); }
  .stamp.priority-High{ color:var(--gold); border-color:var(--gold); }
  .stamp.priority-Medium{ color:var(--blue); border-color:var(--blue); }
  .stamp.priority-Low{ color:var(--green); border-color:var(--green); }

  .status-pill{
    font-size:11px; text-transform:uppercase; letter-spacing:0.06em; font-weight:600;
    padding:4px 10px; border-radius:12px;
  }
  .status-Submitted{ background:#e3e0d4; color:var(--ink-soft); }
  .status-In-Progress{ background:#dde8ee; color:var(--blue); }
  .status-Resolved{ background:#e0ece3; color:var(--green); }
  .status-Rejected{ background:#f3ddd9; color:var(--red); }

  .empty-state{
    text-align:center; padding:60px 20px; color:var(--ink-soft);
  }
  .empty-state h3{ margin-bottom:8px; color:var(--ink); }

  /* ---------- success stamp after filing ---------- */
  .receipt{
    border:2px solid var(--ink); border-radius:6px; padding:24px;
    background:var(--paper); margin-top:24px;
  }
  .receipt-head{ display:flex; justify-content:space-between; align-items:baseline; margin-bottom:14px; }
  .receipt-head .ticket-id{ font-size:13px; }
  .receipt-row{ display:flex; justify-content:space-between; font-size:13px; padding:6px 0; border-bottom:1px dotted var(--line-soft); }
  .receipt-row:last-child{ border-bottom:none; }
  .receipt-row .k{ color:var(--ink-soft); text-transform:uppercase; font-size:11px; letter-spacing:0.06em; }

  .spinner{
    display:inline-block; width:14px; height:14px; border:2px solid var(--paper);
    border-top-color:transparent; border-radius:50%; animation:spin 0.7s linear infinite; margin-right:8px; vertical-align:-2px;
  }
  @keyframes spin{ to{ transform:rotate(360deg); } }

  @media (max-width:640px){
    .topbar, .tabs, .panel{ padding-left:16px; padding-right:16px; }
    .panel{ padding:22px; }
    .ticket{ flex-direction:column; }
    .stamp-col{ flex-direction:row; align-items:center; width:100%; }
  }
</style>
</head>
<body>
<div id="app"></div>

<script>
/* ======================================================
   CONFIG
   Point this at wherever the FastAPI backend is deployed.
   The backend's CORS is currently set to allow_origins=["*"],
   so this can be changed freely without a backend change.
====================================================== */
const API_BASE_URL = "http://localhost:8000";

/* ======================================================
   STATE
   Token is kept in memory only (no localStorage/sessionStorage),
   so refreshing the page will log the user out. Swap in real
   persistent storage (or httpOnly cookies) if that's not desired.
====================================================== */
const state = {
  token: null,
  user: null,        // {id, name, email, role} — from GET /me
  view: "login",      // login | signup | dashboard
  dashboardTab: "new", // new | mine
  complaints: null,
  loading: false,
  error: null,
  info: null,
  receipt: null,
};

function render(){
  const app = document.getElementById("app");
  if (state.view === "login" || state.view === "signup"){
    app.innerHTML = renderAuth();
    bindAuthEvents();
  } else {
    app.innerHTML = renderDashboard();
    bindDashboardEvents();
  }
}

/* ---------------- API ----------------
   Talks to the real FastAPI backend:
   POST /signup   { name, email, password }
   POST /login    { email, password }        -> { access_token, token_type, role }
   GET  /me                                  -> { id, name, email, role }
   POST /complaint { title, description, location } -> { complaint_id, ai_result }
   GET  /complaints?limit=&offset=           -> [ complaint, ... ]  (all complaints;
                                                  filtered to the current user client-side below,
                                                  since the endpoint doesn't scope by user yet)
--------------------------------------- */
async function api(path, options = {}){
  const headers = Object.assign({ "Content-Type": "application/json" }, options.headers || {});
  if (state.token) headers["Authorization"] = "Bearer " + state.token;

  let res;
  try {
    res = await fetch(API_BASE_URL + path, Object.assign({}, options, { headers }));
  } catch (networkErr) {
    throw new Error("Couldn't reach the server. Check your connection and try again.");
  }

  let data = null;
  try { data = await res.json(); } catch (e) { /* empty body */ }

  if (!res.ok){
    const detail = (data && data.detail) ? data.detail : (res.status + " " + res.statusText);
    throw new Error(typeof detail === "string" ? detail : JSON.stringify(detail));
  }
  return data;
}

/* ---------------- AUTH VIEW ---------------- */
function renderAuth(){
  const isSignup = state.view === "signup";
  return `
  <div class="auth-wrap">
    <div class="pass-card">
      <div class="pass-eyebrow">FrontDesk · Campus Complaint Desk</div>
      <h1>${isSignup ? "Create your pass" : "Sign in to file"}</h1>
      <div class="pass-sub">${isSignup ? "Register once to submit and track complaints." : "Enter your credentials to submit or check on a complaint."}</div>

      <div class="switcher">
        <button data-switch="login" class="${!isSignup ? "active" : ""}">Sign in</button>
        <button data-switch="signup" class="${isSignup ? "active" : ""}">Sign up</button>
      </div>

      ${state.error ? `<div class="error-msg">${escapeHtml(state.error)}</div>` : ""}
      ${state.info ? `<div class="info-msg">${escapeHtml(state.info)}</div>` : ""}

      <form id="auth-form">
        ${isSignup ? `
        <div class="field">
          <label>Full name</label>
          <input type="text" name="name" required maxlength="100" placeholder="Aditi Rao" />
        </div>` : ""}
        <div class="field">
          <label>Email</label>
          <input type="email" name="email" required placeholder="you@campus.edu" />
        </div>
        <div class="field">
          <label>Password</label>
          <input type="password" name="password" required minlength="8" maxlength="72" placeholder="••••••••" />
        </div>
        <button type="submit" class="btn-primary" style="width:100%;" ${state.loading ? "disabled" : ""}>
          ${state.loading ? `<span class="spinner"></span>` : ""}${isSignup ? "Create account" : "Sign in"}
        </button>
      </form>
    </div>
  </div>`;
}

function bindAuthEvents(){
  document.querySelectorAll("[data-switch]").forEach(btn => {
    btn.addEventListener("click", () => {
      state.view = btn.getAttribute("data-switch");
      state.error = null; state.info = null;
      render();
    });
  });

  document.getElementById("auth-form").addEventListener("submit", async (e) => {
    e.preventDefault();
    const form = new FormData(e.target);
    state.error = null; state.info = null; state.loading = true; render();
    try {
      if (state.view === "signup"){
        await api("/signup", {
          method: "POST",
          body: JSON.stringify({
            name: form.get("name"),
            email: form.get("email"),
            password: form.get("password"),
          }),
        });
        state.loading = false;
        state.view = "login";
        state.info = "Account created — sign in below.";
        render();
        return;
      } else {
        const data = await api("/login", {
          method: "POST",
          body: JSON.stringify({
            email: form.get("email"),
            password: form.get("password"),
          }),
        });
        state.token = data.access_token;
        const me = await api("/me");
        state.user = me;
        state.loading = false;
        state.view = "dashboard";
        state.dashboardTab = "new";
        render();
      }
    } catch(err){
      state.loading = false;
      state.error = err.message;
      render();
    }
  });
}

/* ---------------- DASHBOARD ---------------- */
function renderDashboard(){
  return `
  <div class="topbar">
    <div class="brand">
      <h1>FrontDesk</h1>
      <span class="tag">Campus Complaint Desk</span>
    </div>
    <div class="userchip">
      <span>${escapeHtml(state.user?.name || "")} · ${escapeHtml(state.user?.email || "")}</span>
      <button class="logout" id="logout-btn">Log out</button>
    </div>
  </div>
  <div class="tabs">
    <div class="tab ${state.dashboardTab === "new" ? "active" : ""}" data-tab="new">File a complaint</div>
    <div class="tab ${state.dashboardTab === "mine" ? "active" : ""}" data-tab="mine">My complaints</div>
  </div>
  <div class="panel">
    ${state.dashboardTab === "new" ? renderNewComplaint() : renderMyComplaints()}
  </div>`;
}

function renderNewComplaint(){
  return `
    ${state.error ? `<div class="error-msg">${escapeHtml(state.error)}</div>` : ""}
    <form id="complaint-form">
      <div class="field">
        <label>Title</label>
        <input type="text" name="title" required maxlength="200" placeholder="e.g. Flickering lights in Block C corridor" />
      </div>
      <div class="field">
        <label>Location</label>
        <input type="text" name="location" required maxlength="100" placeholder="e.g. Hostel Block C, 2nd floor" />
      </div>
      <div class="field">
        <label>Description</label>
        <textarea name="description" required maxlength="2000" placeholder="Describe what's wrong, since when, and how urgent it is."></textarea>
      </div>
      <button type="submit" class="btn-primary" ${state.loading ? "disabled" : ""}>
        ${state.loading ? `<span class="spinner"></span>Filing…` : "Submit complaint"}
      </button>
    </form>
    ${state.receipt ? renderReceipt(state.receipt) : ""}
  `;
}

function renderReceipt(r){
  return `
  <div class="receipt">
    <div class="receipt-head">
      <h3>Complaint filed</h3>
      <span class="ticket-id mono">#${r.complaint_id}</span>
    </div>
    <div class="receipt-row"><span class="k">Category</span><span>${escapeHtml(r.ai_result.category)}</span></div>
    <div class="receipt-row"><span class="k">Priority</span><span>${escapeHtml(r.ai_result.priority)}</span></div>
    <div class="receipt-row"><span class="k">Routed to</span><span>${escapeHtml(r.ai_result.department)}</span></div>
    <div class="receipt-row"><span class="k">Status</span><span>Submitted</span></div>
  </div>`;
}

function renderMyComplaints(){
  if (state.complaints === null){
    return `<div class="empty-state"><h3>Loading your complaints…</h3></div>`;
  }
  const mine = state.complaints.filter(c => c.user_id === state.user.id);
  if (mine.length === 0){
    return `<div class="empty-state"><h3>No complaints filed yet</h3><p>Anything you submit will show up here for tracking.</p></div>`;
  }
  return `<div class="ticket-grid">${mine.map(renderTicket).join("")}</div>`;
}

function renderTicket(c){
  const statusClass = "status-" + String(c.status).replace(/\s+/g, "-");
  return `
  <div class="ticket">
    <div class="ticket-main">
      <div class="ticket-id mono">Ticket #${c.id}</div>
      <div class="ticket-title">${escapeHtml(c.title)}</div>
      <div class="ticket-desc">${escapeHtml(c.description)}</div>
      <div class="ticket-meta">
        <span>📍 ${escapeHtml(c.location || "—")}</span>
        <span>${escapeHtml(c.category)}</span>
        <span>→ ${escapeHtml(c.department)}</span>
        ${c.created_at ? `<span>${formatDate(c.created_at)}</span>` : ""}
      </div>
    </div>
    <div class="stamp-col">
      <div class="stamp priority-${escapeHtml(c.priority)}">${escapeHtml(c.priority)}</div>
      <div class="status-pill ${statusClass}">${escapeHtml(c.status)}</div>
    </div>
  </div>`;
}

function bindDashboardEvents(){
  document.getElementById("logout-btn").addEventListener("click", () => {
    state.token = null; state.user = null; state.complaints = null;
    state.receipt = null; state.error = null; state.view = "login";
    render();
  });

  document.querySelectorAll("[data-tab]").forEach(tab => {
    tab.addEventListener("click", () => {
      state.dashboardTab = tab.getAttribute("data-tab");
      state.error = null;
      if (state.dashboardTab === "mine" && state.complaints === null){
        loadComplaints();
      }
      render();
    });
  });

  const form = document.getElementById("complaint-form");
  if (form){
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const fd = new FormData(e.target);
      state.loading = true; state.error = null; state.receipt = null; render();
      try {
        const result = await api("/complaint", {
          method: "POST",
          body: JSON.stringify({
            title: fd.get("title"),
            description: fd.get("description"),
            location: fd.get("location"),
          }),
        });
        state.loading = false;
        state.receipt = result;
        state.complaints = null; // force refresh next time "My complaints" is opened
        render();
      } catch(err){
        state.loading = false;
        state.error = err.message;
        render();
      }
    });
  }

  if (state.dashboardTab === "mine" && state.complaints === null){
    loadComplaints();
  }
}

async function loadComplaints(){
  try {
    const data = await api("/complaints?limit=200&offset=0");
    state.complaints = data;
    render();
  } catch(err){
    state.error = err.message;
    state.complaints = [];
    render();
  }
}

/* ---------------- utils ---------------- */
function escapeHtml(str){
  if (str === null || str === undefined) return "";
  return String(str)
    .replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;")
    .replace(/"/g,"&quot;").replace(/'/g,"&#39;");
}
function formatDate(iso){
  try {
    const d = new Date(iso);
    return d.toLocaleDateString(undefined, { day:"numeric", month:"short", year:"numeric" });
  } catch(e){ return iso; }
}

render();
</script>
</body>
</html>
